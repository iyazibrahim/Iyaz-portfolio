# Database
DATABASE_URI=postgresql://postgres:postgres@127.0.0.1:5433/your_database?sslmode=disable

# Payload
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin bootstrap (used by seed script)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-after-first-login

# SMTP (contact form notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
SMTP_FROM=you@example.com
CONTACT_NOTIFY_EMAIL=you@example.com
